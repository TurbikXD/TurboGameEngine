{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 24,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "debug",
      "displayName": "Debug",
      "description": "Debug build with OpenGL backend by default",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "ENGINE_BACKEND": "opengl",
        "ENGINE_ENABLE_VULKAN": "ON"
      }
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Release build with OpenGL backend by default",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_CONFIGURATION_TYPES": "Release",
        "ENGINE_BACKEND": "opengl",
        "ENGINE_ENABLE_VULKAN": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug",
      "configuration": "Debug"
    },
    {
      "name": "release",
      "configurePreset": "release",
      "configuration": "Release"
    }
  ]
}
